        "target_dir": "C:\\PrinterBackup",
        "zip_file": "C:\\PrinterBackup\\printserver_backup.zip"
      },
      {
        "task": "StorDiag",
        "output_dir": "C:\\Logs\\StorageDiag"
      },
      {
        "task": "SigVerif"
      },
      {
        "task": "Query",
        "subcommand": "session"
      },
      {
        "task": "FltMc",
        "filter_name": "bindflt"
      },
      {
        "task": "At",
        "schedule_time": "23:00",
        "command": "C:\\Scripts\\nightly_maintenance.bat",
        "recurring": true
      },
      {
        "task": "Cmdkey",
        "target": "fileserver.corp.internal",
        "username": "svcbackup"
      },
      {
        "task": "PktMon",
        "action": "list"
      },
      {
        "task": "OdbcConf",
        "driver_name": "CorpSQLDriver",
        "dsn_name": "CorpERP_DSN"
      },
      {
        "task": "ConfigSecurityPolicy",
        "policy_path": "C:\\GPO\\CorporateSecurityPolicy.inf"
