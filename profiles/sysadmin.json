        "key": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion"
      },
      {
        "task": "Regedit",
        "nav_key": "HKEY_LOCAL_MACHINE\\SYSTEM\\CurrentControlSet\\Services",
        "browse_time": 15
      },
      {
        "task": "WmicQuery",
        "query": "os get Caption,Version,BuildNumber,LastBootUpTime"
      },
      {
        "task": "MpCmdRun",
        "scan_type": "quick",
        "update_sigs": true
      },
      {
        "task": "Netsh",
        "query": "firewall"
      },
      {
        "task": "BitsAdmin",
        "job_name": "WindowsUpdate"
      },
      {
        "task": "Certutil",
        "target_file": "C:\\Windows\\System32\\drivers\\etc\\hosts",
        "query_store": false
      },
      {
        "task": "CertReq",
        "config_url": "http://ca.corp.internal/certsrv/mscep/mscep.dll",
        "request_file": "C:\\Temp\\server01.req",
        "output_file": "C:\\Temp\\server01.cer"
      },
      {
        "task": "Wuauclt",
        "update_server": "http://wsus.corp.internal:8530"
      },
      {
        "task": "PrintBrm",
