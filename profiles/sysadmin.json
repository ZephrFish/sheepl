{
  "sheepl": {
    "name": "Atlas",
    "total_time": "45m",
    "typing_speed": 75,
    "loop": "True",
    "icon": "False",
    "tasks": [
      {
        "task": "SchTasks",
        "action": "create",
        "task_name": "DailyBackup",
        "task_command": "robocopy C:\\Data \\\\fileserver\\backup\\daily /MIR",
        "schedule": "daily"
      },
      {
        "task": "ServiceControl",
        "action": "query",
        "service_name": "wuauserv"
      },
      {
        "task": "Reg",
